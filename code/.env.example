# Copy to code/.env (gitignored). Secrets are read from the environment only and are
# auto-loaded from code/.env by evidence_review/config.py. Real shell env vars win.

# --- Provider credentials -----------------------------------------------------
# Azure AI Foundry (Anthropic-compatible) — set BOTH of these:
ANTHROPIC_API_KEY=...
ANTHROPIC_BASE_URL=https://<your-resource>.services.ai.azure.com/anthropic

# Or first-party Anthropic API — set only the key, leave ANTHROPIC_BASE_URL unset:
# ANTHROPIC_API_KEY=sk-ant-...

# Or the Foundry SDK helper:
# ANTHROPIC_FOUNDRY_API_KEY=...
# ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource-name

# --- LLM tunables (optional; defaults shown) ----------------------------------
LLM_MODEL=claude-sonnet-4-6      # short key (opus|sonnet|haiku) or a full model id
LLM_MAX_TOKENS=4096              # output cap for the structured tool response
LLM_TIMEOUT_SECONDS=60           # per-request timeout
LLM_MAX_RETRIES=4                # backoff retries on 429 / timeout / 5xx
LLM_ENABLE_PROMPT_CACHE=true     # ephemeral prompt caching on the system prompt
LLM_THINKING_ENABLED=false       # extended thinking (uses tool_choice=auto when true)
